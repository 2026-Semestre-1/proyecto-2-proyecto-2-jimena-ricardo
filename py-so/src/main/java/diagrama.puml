' ============================================
' RELACIONES ENTRE PAQUETES
' ============================================

UI --> OperatingSystem : usa

OperatingSystem *-- "1..4" CPU
OperatingSystem *-- "1..4" Dispatcher
OperatingSystem *-- RAM
OperatingSystem *-- Disk
OperatingSystem *-- Scheduler
OperatingSystem --> SchedulerStrategy : usa
OperatingSystem --> UI

Dispatcher *-- CPU
Dispatcher --> Scheduler
Dispatcher --> InterruptHandler
Dispatcher --> OSProcess

Scheduler *-- JobQueue
Scheduler *-- ReadyQueue
Scheduler *-- WaitingQueue
Scheduler --> RAM
Scheduler --> Disk

ReadyQueue ..|> IProcessQueue

FCFS ..|> SchedulerStrategy
RoundRobin ..|> SchedulerStrategy

CPU --> OSProcess : ejecuta

OSProcess *-- BCP
OSProcess *-- Instruction

BCP *-- ProcessStack
BCP --> BCP : nextBCP

Disk *-- DiskEntry
Disk *-- SwapEntry

LoadASM ..> Instruction : crea

InterruptHandler --> CPU
InterruptHandler --> Disk

CPUPanel --> CPU : actualiza

@enduml